# ─── ConnectWorld Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Environment
NODE_ENV=development
PORT=5001

# Database (MySQL)
DATABASE_URL="mysql://root:your_password@127.0.0.1:3306/connectworld"

# Redis (optional - app runs without it)
REDIS_URL=redis://localhost:6379

# JWT Secrets (minimum 32 characters each)
JWT_ACCESS_SECRET=change-this-to-a-random-string-at-least-32-chars!!
JWT_REFRESH_SECRET=change-this-to-another-random-string-at-least-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5001/api/auth/github/callback

# Email (SMTP) - optional, required for email verification & password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@connectworld.app

# Cloudinary (optional, for file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry Error Monitoring (optional)
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
