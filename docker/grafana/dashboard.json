{
  "title": "ConnectWorld - System Overview",
  "uid": "connectworld-overview",
  "tags": ["connectworld", "production"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "title": "API Request Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "title": "Active WebSocket Connections",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "socket_io_connections",
          "legendFormat": "connections"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "title": "HTTP Error Rate (5xx)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "errors"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "title": "API Response Time (P95)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    },
    {
      "title": "Active Meetings",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "connectworld_active_meetings",
          "legendFormat": "active"
        }
      ],
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 16}
    },
    {
      "title": "Online Users",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "connectworld_online_users",
          "legendFormat": "users"
        }
      ],
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 16}
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "MB"
        }
      ],
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 16}
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[5m]) * 100",
          "legendFormat": "%"
        }
      ],
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 16}
    }
  ]
}
